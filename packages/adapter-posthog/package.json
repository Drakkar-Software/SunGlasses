{
  "name": "@drakkar.software/sunglasses-adapter-posthog",
  "version": "0.9.0",
  "description": "PostHog bridge for SunGlasses — forwards PostHog events as SunGlasses analytics events",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@drakkar.software/sunglasses-core": "workspace:*"
  },
  "peerDependencies": {
    "posthog-js": ">=1.187.0",
    "posthog-react-native": "*"
  },
  "peerDependenciesMeta": {
    "posthog-js": {
      "optional": true
    },
    "posthog-react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@drakkar.software/sunglasses-tsconfig": "workspace:*",
    "@posthog/core": "^1.37.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
