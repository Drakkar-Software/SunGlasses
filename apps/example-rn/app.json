{
  "expo": {
    "name": "SunGlasses Example (RN)",
    "slug": "sunglasses-example-rn",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sunglasses-example",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
