{
  "name": "analytics-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"tsx watch --env-file=.env server/server.ts\" \"vite\"",
    "dev:server": "tsx watch --env-file=.env server/server.ts",
    "dev:web": "vite",
    "build": "tsc --noEmit && vite build",
    "start": "tsx --env-file=.env server/server.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.web.json",
    "clean": "rm -rf dist .s3-config.local.json .starfish-config.local.json .parquet-cache",
    "seed:demo": "tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@drakkar.software/starfish-client": "3.0.0-alpha.44",
    "@drakkar.software/starfish-protocol": "3.0.0-alpha.44",
    "@duckdb/node-api": "1.5.4-r.1",
    "@fastify/static": "^9.1.1",
    "fastify": "^5.8.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@drakkar.software/sunglasses-tsconfig": "workspace:*",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
