# DuckDB local staging file (bufffers events between flushes; survives restarts)
DUCKDB_STAGING_PATH=./.staging.duckdb

# Flush policy: whichever threshold is reached first triggers a flush to S3
FLUSH_INTERVAL_MS=60000
FLUSH_MAX_ROWS=5000
